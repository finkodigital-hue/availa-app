# Browser-safe Supabase values. `VITE_` values are bundled into the client and
# must only ever use the project's publishable/anon key.
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Runtime equivalents used by the Cloudflare Worker. These are still
# browser-safe and are intentionally exposed by the server runtime config.
SUPABASE_PROJECT_ID=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=

# Server-only Supabase admin key. Never prefix this with `VITE_`, never place
# it in client code, and store it as an encrypted Cloudflare secret in production.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only third-party credentials. Never prefix any of these with `VITE_`.
ANTHROPIC_API_KEY=
SCREENSHOTONE_ACCESS_KEY=
# Server-only Stripe secret key. Never prefix this with VITE_ or expose it in the browser.
STRIPE_SECRET_KEY=
# Signing secret for Stripe's /api/stripe-webhook endpoint. Keep server-only.
STRIPE_WEBHOOK_SECRET=
# Public origin used for Stripe's secure onboarding return links, and for
# the action links (Confirm/Cancel/Reschedule) in reminder emails.
APP_URL=http://localhost:5173

# Server-only Resend API key used for booking confirmation/reminder emails.
# Not the same integration as Supabase Auth's SMTP (that only sends
# Supabase's own auth templates) — this is Resend's REST API directly.
RESEND_API_KEY=

# Shared secret the Supabase pg_cron sweep presents as a Bearer token when
# it calls /api/cron/send-reminders. Server-only, no VITE_ prefix. Must match
# the value stored in Supabase Vault as 'cron_reminder_secret'.
CRON_REMINDER_SECRET=

# --- Outbound email safety net (src/lib/resend.server.ts) ---
# APP_ENV must be set to exactly "production" — and ONLY on the real
# production environment — for any email to actually reach its real
# recipient. Leave unset here (and everywhere except the production
# Cloudflare environment scope) so local dev and preview deployments never
# reach a real inbox. NOT the same as NODE_ENV, which Vite sets to
# "production" for every build regardless of deploy target.
APP_ENV=

# Where non-production sends are redirected instead (e.g. your own inbox).
# Leave unset to suppress non-production email entirely rather than
# redirect it.
EMAIL_OVERRIDE_TO=
