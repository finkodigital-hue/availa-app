# Browser-safe Supabase values. `VITE_` values are bundled into the client and
# must only ever use the project's publishable/anon key.
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Runtime equivalents used by the Cloudflare Worker. These are still
# browser-safe and are intentionally exposed by the server runtime config.
SUPABASE_PROJECT_ID=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=

# Server-only Supabase admin key. Never prefix this with `VITE_`, never place
# it in client code, and store it as an encrypted Cloudflare secret in production.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only third-party credentials. Never prefix any of these with `VITE_`.
ANTHROPIC_API_KEY=
SCREENSHOTONE_ACCESS_KEY=
# Server-only Stripe secret key. Never prefix this with VITE_ or expose it in the browser.
STRIPE_SECRET_KEY=
# Signing secret for Stripe's /api/stripe-webhook endpoint. Keep server-only.
STRIPE_WEBHOOK_SECRET=
# Public origin used for Stripe's secure onboarding return links.
APP_URL=http://localhost:5173
