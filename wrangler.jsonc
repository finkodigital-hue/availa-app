{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "availa-app",
  "main": ".output/server/index.mjs",
  "compatibility_date": "2026-07-23",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": ".output/public"
  },
  "no_bundle": true,
  "rules": [
    {
      "type": "ESModule",
      "globs": ["**/*.mjs", "**/*.js"]
    }
  ],
  "keep_vars": true
}
